---
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar/Navbar.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import Button from '@components/Button/Button.astro';
import { Picture } from 'astro:assets';

import header from '@images/mobiletire.png';
import Footer from '@components/Footer/Footer.astro';

import img1 from '@images/36-products-3.jpg';
import img2 from '@images/36-shelf.jpg';
import img3 from '@images/36-social.jpg';
---

<Layout
    title="Thirty6Xposures Project | IICON Creative Strategies"
    seo={{
        description:
            'Read about our event project for Thirty6Xposures, a photography challenge and documentary film gift program.'
    }}
>
    <div class="relative flex flex-col">
        <div class="fixed top-0 right-0 left-0 z-50 h-fit bg-black">
            <Navbar />
        </div>
        <div
            class="relative grid h-fit w-full grid-cols-12 gap-fluid-twenty bg-white pt-36 pr-fluid-twenty pb-fluid-eighty pl-fluid-twenty sm:pb-fluid-270"
        >
            <div
                class="col-span-12 flex h-fit flex-col gap-4 self-start text-body-md leading-[110%] tracking-[-2%] sm:sticky sm:top-24 sm:col-span-4 3xl:col-span-3"
            >
                <div class="pb-fluid-eighty md:pb-0">
                    <h1>Thirty6Xposures</h1>
                    <h2 class="text-[#3e3e3e]">Product Sourcing, Event</h2>
                </div>
                <div class="flex flex-row justify-start">
                    <a class="hover-underline w-fit text-body-sm tracking-[-1%]" href="/work"
                        >See all projects ↗</a
                    >
                </div>
                <div
                    class="desktop-version flex flex-col gap-fluid-twenty bg-[#EEEEEE] p-fluid-thirty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
                >
                    <h4 class="pb-fluid-twenty text-body-sm">Project Description</h4>
                    <p>
                        To mark the launch of Season 2 of the thirty6Xposures Photography Challenge
                        & Documentary Film, the producer wanted an on‑brand gift that was
                        distinctive, practical, and unmistakably 36X. The Asobu Orb tumbler
                        delivered, standing out in vibrant signature yellow with a rounded form
                        reminiscent of a Kodak film canister.
                    </p>

                    <p>
                        Finished with a clean black logo and paired with a 36X‑branded black trucker
                        hat, the set felt bold, cohesive, and purposeful. Presented on the first day
                        of filming, the gifts quickly became favourites—used on set, shared across
                        social media, and even featured in the documentary. Their strong visual
                        impact helped generate buzz beyond the shoot, sparking new interest from
                        photographers, sponsors, and media partners, including a major Toronto
                        outlet exploring future collaboration.
                    </p>
                </div>
            </div>
            <div
                class="mob-version col-span-12 flex flex-col gap-fluid-twenty bg-[#EEEEEE] px-fluid-forty pt-fluid-forty pb-fluid-eighty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
            >
                <h4 class="pb-fluid-160 text-body-sm">Project Description</h4>
                <p>
                    To mark the launch of Season 2 of the thirty6Xposures Photography Challenge &
                    Documentary Film, the producer wanted an on‑brand gift that was distinctive,
                    practical, and unmistakably 36X. The Asobu Orb tumbler delivered, standing out
                    in vibrant signature yellow with a rounded form reminiscent of a Kodak film
                    canister.
                </p>

                <p>
                    Finished with a clean black logo and paired with a 36X‑branded black trucker
                    hat, the set felt bold, cohesive, and purposeful. Presented on the first day of
                    filming, the gifts quickly became favourites—used on set, shared across social
                    media, and even featured in the documentary. Their strong visual impact helped
                    generate buzz beyond the shoot, sparking new interest from photographers,
                    sponsors, and media partners, including a major Toronto outlet exploring future
                    collaboration.
                </p>
            </div>
            <div
                class="col-span-12 flex w-full flex-col gap-fluid-twenty sm:col-span-8 3xl:col-span-9"
            >
                <Picture src={img1} alt="ISEAD Awards" class="h-auto w-full" loading="lazy" />
                <Picture src={img2} alt="ISEAD Awards" class="h-auto w-full" loading="lazy" />
                <Picture src={img3} alt="ISEAD Group Photo" class="h-auto w-full" loading="lazy" />
            </div>
        </div>
    </div>
    <Footer />
</Layout>
