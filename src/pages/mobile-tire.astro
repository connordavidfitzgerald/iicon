---
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar/Navbar.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import Button from '@components/Button/Button.astro';
import { Picture } from 'astro:assets';
import flatLay from '@images/MB Crew Apparel.jpg';
import flatLayTwo from '@images/MB Crew Winter.jpg';
import header from '@images/mobiletire.png';
import Footer from '@components/Footer/Footer.astro';
---

<Layout
    title="Mobile Tire Project | IICON Creative Strategies"
    seo={{
        description:
            'Discover our work with Mobile Tire, a project involving product sourcing and brand strategy to develop a professional uniform program.'
    }}
>
    <div class="relative flex flex-col">
        <div class="fixed top-0 right-0 left-0 z-50 h-fit bg-black">
            <Navbar />
        </div>
        <div
            class="relative grid h-fit w-full grid-cols-12 gap-fluid-twenty bg-white pt-36 pr-fluid-twenty pb-fluid-eighty pl-fluid-twenty sm:pb-fluid-270"
        >
            <div
                class="col-span-12 flex h-fit flex-col gap-4 self-start text-body-md leading-[100%] tracking-[-3%] sm:sticky sm:top-24 sm:col-span-4 3xl:col-span-3"
            >
                <div class="pb-fluid-eighty md:pb-0">
                    <h1>Mobile Tire</h1>
                    <h2 class="text-[#3e3e3e]">Product Sourcing, Strategy</h2>
                </div>
                <div class="flex flex-row justify-start">
                    <a class="hover-underline w-fit text-body-sm tracking-[-1%]" href="/work"
                        >See all projects ↗</a
                    >
                </div>
                <div
                    class="desktop-version flex flex-col gap-fluid-twenty bg-[#EEEEEE] p-fluid-thirty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
                >
                    <h4 class="pb-fluid-twenty text-body-sm">Project Description</h4>
                    <p>
                        Mobile Tire was founded to provide professional mobile in-home, in-office or
                        anywhere/anytime seasonal tire changes, from domestic vehicles to imported
                        luxury and sports cars.
                    </p>

                    <p>
                        The objective of the Mobile Tire Uniform Program was to develop and
                        establish a brand presence that reflects professionalism, reliability, and
                        trust which can be leveraged into franchising opportunities. In addition,
                        the program aimed to create continuity and consistency with their existing
                        website and service vehicle graphics; to outfit the crew with workwear that
                        was comfortable, streamlined, durable, and suitable for various weather
                        conditions.
                    </p>
                    <p>
                        We selected apparel that was predominantly black as the colour is associated
                        with strength, formality, and seriousness. An existing 2-colour logo in blue
                        and white and tagline was placed on the full back and upper left chest of
                        the jackets and golf shirts for the best brand visibility. We used the red
                        Canadian leaf embroidered on the hats to express Canadian pride.
                    </p>
                </div>
            </div>
            <div
                class="mob-version col-span-12 flex flex-col gap-fluid-twenty bg-[#EEEEEE] px-fluid-forty pt-fluid-forty pb-fluid-eighty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
            >
                <h4 class="pb-fluid-160 text-body-sm">Project Description</h4>
                <p>
                    Mobile Tire was founded to provide professional mobile in-home, in-office or
                    anywhere/anytime seasonal tire changes, from domestic vehicles to imported
                    luxury and sports cars.
                </p>

                <p>
                    The objective of the Mobile Tire Uniform Program was to develop and establish a
                    brand presence that reflects professionalism, reliability, and trust which can
                    be leveraged into franchising opportunities. In addition, the program aimed to
                    create continuity and consistency with their existing website and service
                    vehicle graphics; to outfit the crew with workwear that was comfortable,
                    streamlined, durable, and suitable for various weather conditions.
                </p>
                <p>
                    We selected apparel that was predominantly black as the colour is associated
                    with strength, formality, and seriousness. An existing 2-colour logo in blue and
                    white and tagline was placed on the full back and upper left chest of the
                    jackets and golf shirts for the best brand visibility. We used the red Canadian
                    leaf embroidered on the hats to express Canadian pride.
                </p>
            </div>
            <div
                class="col-span-12 flex w-full flex-col gap-fluid-twenty sm:col-span-8 3xl:col-span-9"
            >
                <Picture
                    src={header}
                    alt="Mobile Tire Apparel"
                    class="h-auto w-full"
                    loading="lazy"
                />
                <Picture
                    src={flatLay}
                    alt="Mobile Tire Apparel"
                    class="h-auto w-full"
                    loading="lazy"
                />
                <Picture
                    src={flatLayTwo}
                    alt="Mobile Tire Apparel"
                    class="h-auto w-full"
                    loading="lazy"
                />
            </div>
        </div>
    </div>
    <Footer />
</Layout>
