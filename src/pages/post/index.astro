---
import Layout from '@layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { CssVariable } from 'astro:assets';

interface Post {
    _id: string;
    title: string;
    slug: { current: string };
    publishedAt: string;
    image?: any;
}

const posts = await sanityClient.fetch<Post[]>(
    `*[_type == "post"] | order(publishedAt desc) {
        _id,
        title,
        slug,
        publishedAt,
        image
    }`
);
---

<Layout title="Posts">
    <div class="min-h-screen w-full bg-[#F3F3F3] py-20">
        <div class="container grid grid-cols-12 gap-gutter">
            <div class="md:col-span-1"></div>
            <div class="md:col-span-10">
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                    {
                        posts.map((post) => (
                            <a href={`/posts/${post.slug.current}`} class="group block">
                                <article class="overflow-hidden">
                                    {post.image && (
                                        <div class="mb-4 aspect-[4/3] overflow-hidden"></div>
                                    )}
                                    <h2 class="text-md font-medium tracking-[-0.5%] text-white mix-blend-difference transition-opacity group-hover:opacity-70">
                                        {post.title}
                                    </h2>
                                </article>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</Layout>
