---
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar/Navbar.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import Button from '@components/Button/Button.astro';
import { Picture } from 'astro:assets';

import header from '@images/mobiletire.png';
import Footer from '@components/Footer/Footer.astro';

import img1 from '@images/isead-awards-still.jpg';
import img2 from '@images/isead-awards-still-2.jpg';
import img3 from '@images/isead-awards.jpg';
import img4 from '@images/isead-awards-2.jpg';
---

<Layout title="IICON">
    <div class="relative flex flex-col">
        <div class="fixed top-0 right-0 left-0 z-50 h-fit bg-black">
            <Navbar />
        </div>
        <div
            class="relative grid h-fit w-full grid-cols-12 gap-fluid-twenty bg-white pt-36 pr-fluid-twenty pb-fluid-eighty pl-fluid-twenty sm:pb-fluid-270"
        >
            <div
                class="col-span-12 flex h-fit flex-col gap-4 self-start text-body-md leading-[100%] tracking-[-3%] sm:sticky sm:top-24 sm:col-span-4 3xl:col-span-3"
            >
                <div class="pb-fluid-eighty md:pb-0">
                    <h1>ISEAD</h1>
                    <h2 class="text-[#3e3e3e]">Product Sourcing, Strategy, Event</h2>
                </div>
                <div class="flex flex-row justify-start">
                    <a class="hover-underline w-fit text-body-sm tracking-[-1%]" href="/work"
                        >See all projects ↗</a
                    >
                </div>
                <div
                    class="desktop-version flex flex-col gap-fluid-twenty bg-[#EEEEEE] p-fluid-thirty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
                >
                    <h4 class="pb-fluid-twenty text-body-sm">Project Description</h4>
                    <p>
                        Indigenous Skills Employment Apprenticeship and Development, formerly AABO,
                        marked a pivotal new chapter and a new name at its November 2024 conference.
                        To commemorate this milestone, we created ISEAD’s inaugural award—a symbol
                        of strength, unity, and shared purpose—honoring partnerships with Canadian
                        Building Trades Unions and Indigenous communities.
                    </p>

                    <p>
                        Handcrafted in Canada from sustainably sourced wood and Lucite, the design
                        featured a feather transforming into birds in flight, representing growth,
                        evolution, and new identity. Presented to only five recipients, the award
                        debuted at an intimate gala attended by 150–200 national leaders.
                    </p>
                    <p>
                        A particularly memorable highlight was a photo of the Minister of Labor
                        holding the ISEAD Diversity Award. He praised the design, noting how
                        beautifully it captured the spirit of the organization. This was widely
                        celebrated across media platforms helping amplify the moment and placed
                        ISEAD and the conference firmly on the map.
                    </p>
                    <p>
                        During the gala, the director of the Indigenous Organization gave a
                        heartfelt reflection on our design and commitment to the project.A touching
                        moment came when Rose was asked to sign the bottom of two awards by union
                        leaders. This program achieved its goals of recognition, engagement, and
                        cultural alignment, inspiring continued commitment to ISEAD’s mission.
                    </p>
                    <p class="pt-fluid-forty text-body-sm opacity-90">
                        Awards:<br /><br />
                        <span class="italic"
                            >The Spirit of Partnership: Not for Profit Category</span
                        ><br />
                        PPAI Silver Pyramid Award (International)<br />
                        PPPC Silver Image Award (Canada)<br />
                    </p>
                </div>
            </div>
            <div
                class="mob-version col-span-12 flex flex-col gap-fluid-twenty bg-[#EEEEEE] px-fluid-forty pt-fluid-forty pb-fluid-eighty text-body-project leading-[120%] tracking-[-2%] text-[#3e3e3e]"
            >
                <h4 class="pb-fluid-160 text-body-sm">Project Description</h4>
                <p>
                    Indigenous Skills Employment Apprenticeship and Development, formerly AABO,
                    marked a pivotal new chapter and a new name at its November 2024 conference. To
                    commemorate this milestone, we created ISEAD’s inaugural award—a symbol of
                    strength, unity, and shared purpose—honoring partnerships with Canadian Building
                    Trades Unions and Indigenous communities.
                </p>

                <p>
                    Handcrafted in Canada from sustainably sourced wood and Lucite, the design
                    featured a feather transforming into birds in flight, representing growth,
                    evolution, and new identity. Presented to only five recipients, the award
                    debuted at an intimate gala attended by 150–200 national leaders.
                </p>
                <p>
                    A particularly memorable highlight was a photo of the Minister of Labor holding
                    the ISEAD Diversity Award. He praised the design, noting how beautifully it
                    captured the spirit of the organization. This was widely celebrated across media
                    platforms helping amplify the moment and placed ISEAD and the conference firmly
                    on the map.
                </p>
                <p>
                    During the gala, the director of the Indigenous Organization gave a heartfelt
                    reflection on our design and commitment to the project.A touching moment came
                    when Rose was asked to sign the bottom of two awards by union leaders. This
                    program achieved its goals of recognition, engagement, and cultural alignment,
                    inspiring continued commitment to ISEAD’s mission.
                </p>
                <p class="pt-fluid-forty text-body-sm opacity-90">
                    Awards:<br /><br />
                    <span class="italic">The Spirit of Partnership: Not for Profit Category</span
                    ><br />
                    PPAI Silver Pyramid Award (International)<br />
                    PPPC Silver Image Award (Canada)<br />
                </p>
            </div>
            <div
                class="col-span-12 flex w-full flex-col gap-fluid-twenty sm:col-span-8 3xl:col-span-9"
            >
                <Picture src={img1} alt="ISEAD Awards" class="h-auto w-full" loading="lazy" />
                <Picture src={img2} alt="ISEAD Awards" class="h-auto w-full" loading="lazy" />
                <Picture src={img3} alt="ISEAD Group Photo" class="h-auto w-full" loading="lazy" />
                <Picture src={img4} alt="ISEAD Group Photo" class="h-auto w-full" loading="lazy" />
            </div>
        </div>
    </div>
    <Footer />
</Layout>
