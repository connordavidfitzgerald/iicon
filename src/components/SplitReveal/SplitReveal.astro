---
interface Props {
    tag?: 'h1' | 'h2' | 'h3' | 'p' | 'span';
    class?: string;
}

const { tag: Tag = 'p', class: className = '' } = Astro.props;
---

<split-reveal style="display: contents;">
    <Tag data-split class={className}>
        <slot />
    </Tag>
</split-reveal>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';

    gsap.registerPlugin(ScrollTrigger, SplitText);

    class SplitReveal extends HTMLElement {
        connectedCallback() {
            const el = this.querySelector('[data-split]');
            if (!el) return;

            document.fonts.ready.then(() => {
                new SplitText(el, {
                    type: 'words',
                    mask: 'words',
                    wordsClass: 'word++',
                    autoSplit: true,

                    onSplit(self) {
                        (gsap.set(self.masks, {
                            overflowX: 'visible'
                        }),
                            gsap.from(self.words, {
                                yPercent: -120,
                                duration: 1,
                                ease: 'power3.out',
                                stagger: 0.02,

                                onComplete: () => self.revert(),
                                scrollTrigger: {
                                    trigger: el,
                                    start: 'top 100%',
                                    once: true
                                }
                            }));
                    }
                });

                ScrollTrigger.refresh();
            });
        }
    }
</script>

<style>
    [data-split] {
        font-kerning: none;
        text-rendering: optimizeSpeed;
    }
</style>
