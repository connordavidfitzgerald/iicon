---
interface Props {
    tag?: 'h1' | 'h2' | 'h3' | 'p' | 'span';
    class?: string;
    color?: string;
}

const { tag: Tag = 'p', class: className = '', color = '#ff922d' } = Astro.props;
---

<div class="src-wrapper" style="position: relative; display: inline-block;">
    <div
        class="src-overlay"
        style={`position: absolute; inset: 0; background: ${color}; z-index: 1; pointer-events: none;`}
    >
    </div>
    <Tag data-split class={className}>
        <slot />
    </Tag>
</div>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';

    gsap.registerPlugin(ScrollTrigger, SplitText);

    function init() {
        document.querySelectorAll('.src-wrapper').forEach((wrapper) => {
            if (wrapper.hasAttribute('data-src-init')) return;
            wrapper.setAttribute('data-src-init', '');

            const overlay = wrapper.querySelector('.src-overlay') as HTMLElement;
            const textEl = wrapper.querySelector('[data-split]') as HTMLElement;
            if (!overlay || !textEl) return;

            // Split into words + lines, but DON'T use SplitText's built-in mask
            // (it uses clip-path internally which breaks near the bottom of the viewport)
            const split = SplitText.create(textEl, {
                type: 'words'
            });

            var tl = gsap.timeline({
                ScrollTrigger: {
                    trigger: wrapper,
                    start: 'top 100%'
                }
            });
            tl.fromTo(
                overlay,
                { scaleX: 0, transformOrigin: 'left center' },
                {
                    scaleX: 1,
                    duration: 0.45,
                    ease: 'power3.inOut'
                }
            );
            tl.to(overlay, {
                transformOrigin: 'right center',
                scaleX: 0,
                duration: 0.45,
                ease: 'power3.inOut'
            });
        });
    }

    // Initial page load
    init();

    // Re-init after Swup page transitions
    document.addEventListener('app:page-ready', init);
</script>
