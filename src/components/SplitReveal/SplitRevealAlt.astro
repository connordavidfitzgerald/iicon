---
interface Props {
    tag?: 'h1' | 'h2' | 'h3' | 'p' | 'span';
    class?: string;
}

const { tag: Tag = 'p', class: className = '' } = Astro.props;
---

<Tag data-split class={className}>
    <slot />
</Tag>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';

    gsap.registerPlugin(ScrollTrigger, SplitText);

    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-split]').forEach((el) => {
            new SplitText(el, {
                type: 'words',
                mask: 'words',
                autoSplit: true,
                onSplit(self) {
                    gsap.from(self.words, {
                        yPercent: 110,
                        rotation: 1,
                        duration: 1,
                        ease: 'power3.out',
                        stagger: 0.025,
                        scrollTrigger: {
                            trigger: el,
                            start: 'top 100%',
                            once: true
                        }
                    });
                }
            });
        });

        ScrollTrigger.refresh();
    });
</script>
